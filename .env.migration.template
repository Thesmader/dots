# Migration Environment File
# Copy this to .env.migration and fill in the paths before running bootstrap.sh
#
# IMPORTANT: Use double quotes for all values. Paths with spaces will work.
# Example: GPG_KEY_PERSONAL="/Volumes/My USB Drive/personal-gpg.key"

# ── GPG Keys ──
# Export from old machine:
#   gpg --export-secret-keys --armor 23DD47AE58514C18 > /path/to/personal-gpg.key
#   gpg --export-secret-keys --armor 05324CEB5785CB37 > /path/to/work-gpg.key
GPG_KEY_PERSONAL=""
GPG_KEY_WORK=""

# ── SSH Keys ──
# Directory containing your SSH keys (id_ed25519, id_rsa, etc.)
# e.g. a folder on a USB drive or downloaded from Bitwarden
SSH_KEYS_DIR=""

# ── Git ──
GIT_NAME="Thesmader"
GIT_EMAIL_PERSONAL="dsmarak17@gmail.com"
GIT_EMAIL_WORK="smarak.das@marketfeed.com"

# ── Raycast ──
# Export from old machine: Raycast → Settings → Advanced → Export
RAYCAST_EXPORT=""
